# ─────────────────────────────────────────────────────────────────────────────
#  Nexus Financial Group · VaultIQ — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=nexus_genai_showcase

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Voyage AI Embeddings
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-finance-2

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=nexus-genai-showcase

# Custom FastMCP Server (mock Nexus external APIs)
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8100

# MongoDB MCP Server (official @mongodb-js/mongodb-mcp-server)
# MONGODB_MCP_TRANSPORT=embedded  → auto-spawns npx subprocess (default, no extra setup)
# MONGODB_MCP_TRANSPORT=http      → connect to a running server (start it manually)
MONGODB_MCP_TRANSPORT=embedded
MONGODB_MCP_HOST=localhost
MONGODB_MCP_PORT=3001
MONGODB_MCP_READ_ONLY=true

# Atlas Admin API (auto-resume paused cluster on startup)
ATLAS_API_CLIENT_ID=your-service-account-client-id
ATLAS_API_CLIENT_SECRET=your-service-account-client-secret
ATLAS_API_PROJECT_ID=your-atlas-project-id
ATLAS_API_CLUSTER_NAME=your-cluster-name

# App Config
APP_ENV=demo
LOG_LEVEL=INFO
